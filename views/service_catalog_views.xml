<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- ─── Server action to open / create catalog for active profile ──── -->
    <record id="action_server_open_service_catalog" model="ir.actions.server">
      <field name="name">My Services</field>
      <field name="model_id" ref="fulfillment_software.model_fulfillment_profile"/>
      <field name="state">code</field>
      <field name="code">
profile = model.search([], limit=1)
if not profile:
    raise UserError('No profile configured. Go to My account first.')
action = profile.action_open_service_catalog()
      </field>
    </record>

    <!-- ─── Form view for own catalog (editable) ─────────────────────── -->
    <record id="view_fulfillment_service_catalog_form" model="ir.ui.view">
      <field name="name">fulfillment.service.catalog.form</field>
      <field name="model">fulfillment.service.catalog</field>
      <field name="arch" type="xml">
        <form string="My Services">

          <header>
            <button name="action_push_to_api" type="object" string="Publish to API"
                    class="btn-primary" invisible="not is_mine"/>
          </header>

          <sheet>
            <group>
              <div class="oe_title">
                <h1>Service Catalog</h1>
                <p class="text-muted">
                  Define what services you provide as a fulfillment operator.
                  Enable each section you offer, fill in the details, then click
                  <strong>Publish to API</strong> to share your catalog with partners.
                </p>
              </div>
              <group>
                <field name="last_sync_at" readonly="1"/>
              </group>
            </group>

            <notebook>

              <!-- ─── PACKING ─────────────────────────────────────────── -->
              <page string="Packing" name="packing">
                <group>
                  <group string="General">
                    <field name="packing_active" widget="boolean_toggle"/>
                    <field name="packing_currency" invisible="not packing_active"/>
                    <field name="packing_min_order_price" invisible="not packing_active"/>
                    <field name="packing_label_printing" widget="boolean_toggle"
                           invisible="not packing_active"/>
                  </group>
                  <group string="Extra services" invisible="not packing_active">
                    <field name="packing_fragile" widget="boolean_toggle"/>
                    <field name="packing_fragile_price" invisible="not packing_fragile"/>
                    <field name="packing_custom_branding" widget="boolean_toggle"/>
                    <field name="packing_custom_branding_price" invisible="not packing_custom_branding"/>
                    <field name="packing_kitting" widget="boolean_toggle"/>
                    <field name="packing_kitting_price" invisible="not packing_kitting"/>
                    <field name="packing_assembly" widget="boolean_toggle"/>
                    <field name="packing_assembly_price" invisible="not packing_assembly"/>
                    <field name="packing_returns" widget="boolean_toggle"/>
                    <field name="packing_returns_price" invisible="not packing_returns"/>
                  </group>
                </group>

                <group string="Box configurations" invisible="not packing_active">
                  <p class="col-12 text-muted">
                    List every box type you use. Partners will see exactly what packaging
                    options you offer — dimensions, material, included fillers and unit price.
                  </p>
                  <field name="packing_option_ids" nolabel="1">
                    <list editable="bottom">
                      <field name="sequence" widget="handle"/>
                      <field name="name"/>
                      <field name="length_cm"/>
                      <field name="width_cm"/>
                      <field name="height_cm"/>
                      <field name="max_weight_kg"/>
                      <field name="material"/>
                      <field name="fillers"/>
                      <field name="price_per_unit"/>
                      <field name="notes" optional="hide"/>
                    </list>
                  </field>
                </group>

                <group string="Additional notes" invisible="not packing_active">
                  <field name="packing_description" nolabel="1"
                         placeholder="SLA, lead time, restrictions, special requirements …"/>
                </group>
              </page>

              <!-- ─── STORAGE ─────────────────────────────────────────── -->
              <page string="Storage" name="storage">
                <group>
                  <group string="General">
                    <field name="storage_active" widget="boolean_toggle"/>
                    <field name="storage_currency" invisible="not storage_active"/>
                    <field name="storage_min_period_days" invisible="not storage_active"/>
                    <field name="storage_max_pallet_weight_kg" invisible="not storage_active"/>
                  </group>
                  <group string="Security and infrastructure" invisible="not storage_active">
                    <field name="storage_security"/>
                    <field name="storage_cctv" widget="boolean_toggle"/>
                    <field name="storage_fire_suppression" widget="boolean_toggle"/>
                    <field name="storage_insurance" widget="boolean_toggle"/>
                  </group>
                </group>

                <group string="Ambient (dry) storage" invisible="not storage_active">
                  <group>
                    <field name="storage_ambient_active" widget="boolean_toggle"/>
                    <field name="storage_ambient_unit" invisible="not storage_ambient_active"/>
                    <field name="storage_ambient_price_day" invisible="not storage_ambient_active"/>
                    <field name="storage_ambient_price_month" invisible="not storage_ambient_active"/>
                  </group>
                </group>

                <group string="Cold-chain storage" invisible="not storage_active">
                  <group>
                    <field name="storage_cold_active" widget="boolean_toggle"/>
                    <field name="storage_cold_unit" invisible="not storage_cold_active"/>
                    <field name="storage_cold_temp_min" invisible="not storage_cold_active"/>
                    <field name="storage_cold_temp_max" invisible="not storage_cold_active"/>
                    <field name="storage_cold_price_day" invisible="not storage_cold_active"/>
                    <field name="storage_cold_price_month" invisible="not storage_cold_active"/>
                  </group>
                </group>

                <group string="Hazmat / DG goods" invisible="not storage_active">
                  <group>
                    <field name="storage_hazmat" widget="boolean_toggle"/>
                    <field name="storage_hazmat_description" invisible="not storage_hazmat"
                           placeholder="Dangerous goods classes, certifications, restrictions …"/>
                  </group>
                </group>

                <group string="Additional notes" invisible="not storage_active">
                  <field name="storage_description" nolabel="1"
                         placeholder="SLA, access hours, receiving cut-off, insurance details …"/>
                </group>
              </page>

              <!-- ─── SHIPPING ─────────────────────────────────────────── -->
              <page string="Shipping" name="shipping">
                <group>
                  <group string="General">
                    <field name="shipping_active" widget="boolean_toggle"/>
                    <field name="shipping_currency" invisible="not shipping_active"/>
                    <field name="shipping_carrier_ids" widget="many2many_tags"
                           invisible="not shipping_active"
                           options="{'color_field': 'country_group', 'no_create_edit': True}"/>
                    <field name="shipping_handling_fee" invisible="not shipping_active"/>
                    <field name="shipping_max_weight_kg" invisible="not shipping_active"/>
                    <field name="shipping_max_dimensions" invisible="not shipping_active"/>
                  </group>
                  <group string="Options" invisible="not shipping_active">
                    <field name="shipping_tracking" widget="boolean_toggle"/>
                    <field name="shipping_insurance" widget="boolean_toggle"/>
                    <field name="shipping_insurance_percent" invisible="not shipping_insurance"/>
                    <field name="shipping_express" widget="boolean_toggle"/>
                    <field name="shipping_express_price_from" invisible="not shipping_express"/>
                  </group>
                </group>

                <group string="Destinations and pricing" invisible="not shipping_active">
                  <group string="Domestic">
                    <field name="shipping_domestic" widget="boolean_toggle"/>
                    <field name="shipping_domestic_price_from" invisible="not shipping_domestic"/>
                    <field name="shipping_domestic_days" invisible="not shipping_domestic"/>
                  </group>
                  <group string="EU / Regional">
                    <field name="shipping_eu" widget="boolean_toggle"/>
                    <field name="shipping_eu_price_from" invisible="not shipping_eu"/>
                    <field name="shipping_eu_days" invisible="not shipping_eu"/>
                  </group>
                  <group string="Worldwide">
                    <field name="shipping_worldwide" widget="boolean_toggle"/>
                    <field name="shipping_worldwide_price_from" invisible="not shipping_worldwide"/>
                    <field name="shipping_worldwide_days" invisible="not shipping_worldwide"/>
                  </group>
                </group>

                <group string="Additional notes" invisible="not shipping_active">
                  <field name="shipping_description" nolabel="1"
                         placeholder="Pickup schedule, prohibited items, incoterms, special zones …"/>
                </group>
              </page>

              <!-- ─── PRE-SHIPMENT INSPECTION ─────────────────────────── -->
              <page string="Inspection" name="inspection">
                <group>
                  <group string="General">
                    <field name="inspection_active" widget="boolean_toggle"/>
                    <field name="inspection_currency" invisible="not inspection_active"/>
                    <field name="inspection_types" invisible="not inspection_active"/>
                    <field name="inspection_certifications" invisible="not inspection_active"/>
                  </group>
                  <group string="Pricing" invisible="not inspection_active">
                    <field name="inspection_price_per_item"/>
                    <field name="inspection_price_per_order"/>
                    <field name="inspection_min_price"/>
                  </group>
                </group>

                <group string="Sampling and quality criteria" invisible="not inspection_active">
                  <group>
                    <field name="inspection_sampling_rate"/>
                    <field name="inspection_defect_tolerance"/>
                    <field name="inspection_corrective_action" widget="boolean_toggle"/>
                    <field name="inspection_corrective_price" invisible="not inspection_corrective_action"/>
                  </group>
                  <group string="Evidence and reporting">
                    <field name="inspection_photos" widget="boolean_toggle"/>
                    <field name="inspection_photos_count" invisible="not inspection_photos"/>
                    <field name="inspection_video" widget="boolean_toggle"/>
                    <field name="inspection_report_pdf" widget="boolean_toggle"/>
                    <field name="inspection_report_language" invisible="not inspection_report_pdf"/>
                  </group>
                </group>

                <group string="Additional notes" invisible="not inspection_active">
                  <field name="inspection_description" nolabel="1"
                         placeholder="Scope, lead time, certifications, per-product fees, special agreements …"/>
                </group>
              </page>

            </notebook>
          </sheet>
        </form>
      </field>
    </record>

    <!-- ─── Readonly catalog for partner view (popup) ─────────────────── -->
    <record id="view_fulfillment_service_catalog_form_readonly" model="ir.ui.view">
      <field name="name">fulfillment.service.catalog.form.readonly</field>
      <field name="model">fulfillment.service.catalog</field>
      <field name="priority">999</field>
      <field name="arch" type="xml">
        <form string="Partner Service Catalog" create="false" delete="false" edit="false">
          <sheet>
            <group>
              <div class="oe_title">
                <h2>Service Catalog</h2>
              </div>
              <group>
                <field name="last_sync_at" readonly="1"/>
              </group>
            </group>

            <notebook>
              <page string="Packing" name="packing">
                <group invisible="not packing_active">
                  <group string="General">
                    <field name="packing_active" readonly="1"/>
                    <field name="packing_currency" readonly="1"/>
                    <field name="packing_min_order_price" readonly="1"/>
                    <field name="packing_label_printing" readonly="1"/>
                  </group>
                  <group string="Extra services">
                    <field name="packing_fragile" readonly="1"/>
                    <field name="packing_fragile_price" readonly="1" invisible="not packing_fragile"/>
                    <field name="packing_custom_branding" readonly="1"/>
                    <field name="packing_custom_branding_price" readonly="1" invisible="not packing_custom_branding"/>
                    <field name="packing_kitting" readonly="1"/>
                    <field name="packing_assembly" readonly="1"/>
                    <field name="packing_returns" readonly="1"/>
                  </group>
                </group>
                <field name="packing_option_ids" nolabel="1" readonly="1" invisible="not packing_active">
                  <list>
                    <field name="name"/>
                    <field name="length_cm"/>
                    <field name="width_cm"/>
                    <field name="height_cm"/>
                    <field name="max_weight_kg"/>
                    <field name="material"/>
                    <field name="fillers"/>
                    <field name="price_per_unit"/>
                  </list>
                </field>
                <p class="text-muted" invisible="packing_active">
                  This partner does not offer packing services.
                </p>
              </page>

              <page string="Storage" name="storage">
                <group invisible="not storage_active">
                  <group string="General">
                    <field name="storage_ambient_active" readonly="1"/>
                    <field name="storage_ambient_unit" readonly="1" invisible="not storage_ambient_active"/>
                    <field name="storage_ambient_price_month" readonly="1" invisible="not storage_ambient_active"/>
                    <field name="storage_cold_active" readonly="1"/>
                    <field name="storage_cold_temp_min" readonly="1" invisible="not storage_cold_active"/>
                    <field name="storage_cold_temp_max" readonly="1" invisible="not storage_cold_active"/>
                    <field name="storage_min_period_days" readonly="1"/>
                  </group>
                  <group string="Infrastructure">
                    <field name="storage_security" readonly="1"/>
                    <field name="storage_cctv" readonly="1"/>
                    <field name="storage_fire_suppression" readonly="1"/>
                    <field name="storage_insurance" readonly="1"/>
                    <field name="storage_hazmat" readonly="1"/>
                    <field name="storage_max_pallet_weight_kg" readonly="1"/>
                  </group>
                </group>
                <p class="text-muted" invisible="storage_active">
                  This partner does not offer storage services.
                </p>
              </page>

              <page string="Shipping" name="shipping">
                <group invisible="not shipping_active">
                  <group string="Carriers and options">
                    <field name="shipping_carrier_ids" widget="many2many_tags" readonly="1"/>
                    <field name="shipping_tracking" readonly="1"/>
                    <field name="shipping_handling_fee" readonly="1"/>
                    <field name="shipping_max_weight_kg" readonly="1"/>
                  </group>
                  <group string="Destinations">
                    <field name="shipping_domestic" readonly="1"/>
                    <field name="shipping_domestic_price_from" readonly="1" invisible="not shipping_domestic"/>
                    <field name="shipping_domestic_days" readonly="1" invisible="not shipping_domestic"/>
                    <field name="shipping_eu" readonly="1"/>
                    <field name="shipping_eu_price_from" readonly="1" invisible="not shipping_eu"/>
                    <field name="shipping_worldwide" readonly="1"/>
                    <field name="shipping_worldwide_price_from" readonly="1" invisible="not shipping_worldwide"/>
                  </group>
                </group>
                <p class="text-muted" invisible="shipping_active">
                  This partner does not offer shipping services.
                </p>
              </page>

              <page string="Inspection" name="inspection">
                <group invisible="not inspection_active">
                  <group string="General">
                    <field name="inspection_types" readonly="1"/>
                    <field name="inspection_certifications" readonly="1"/>
                    <field name="inspection_sampling_rate" readonly="1"/>
                    <field name="inspection_defect_tolerance" readonly="1"/>
                  </group>
                  <group string="Pricing">
                    <field name="inspection_price_per_item" readonly="1"/>
                    <field name="inspection_price_per_order" readonly="1"/>
                    <field name="inspection_min_price" readonly="1"/>
                  </group>
                  <group string="Reporting">
                    <field name="inspection_photos" readonly="1"/>
                    <field name="inspection_photos_count" readonly="1" invisible="not inspection_photos"/>
                    <field name="inspection_video" readonly="1"/>
                    <field name="inspection_report_pdf" readonly="1"/>
                  </group>
                </group>
                <p class="text-muted" invisible="inspection_active">
                  This partner does not offer pre-shipment inspection.
                </p>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>

  </data>
</odoo>
