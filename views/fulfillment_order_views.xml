<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!-- Sequence for auto-numbering -->
    <record id="seq_fulfillment_order" model="ir.sequence">
        <field name="name">Fulfillment Order</field>
        <field name="code">fulfillment.order</field>
        <field name="prefix">FO/%(year)s/</field>
        <field name="padding">5</field>
    </record>

    <!-- Tree / List view -->
    <record id="view_fulfillment_order_tree" model="ir.ui.view">
        <field name="name">fulfillment.order.tree</field>
        <field name="model">fulfillment.order</field>
        <field name="arch" type="xml">
            <list string="Fulfillment Orders"
                  decoration-muted="state == 'cancelled'"
                  decoration-success="state == 'done'">
                <field name="name" string="Order"/>
                <field name="fulfillment_partner_id" string="Partner"/>
                <field name="source_warehouse_id" string="From"/>
                <field name="dest_warehouse_id" string="To"/>
                <field name="line_count" string="Products" widget="integer"/>
                <field name="state" widget="badge" string="Status"/>
                <field name="picking_state" widget="badge" optional="show" string="Receipt"/>
                <field name="fulfillment_transfer_id" optional="hide" string="API ID"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_fulfillment_order_form" model="ir.ui.view">
        <field name="name">fulfillment.order.form</field>
        <field name="model">fulfillment.order</field>
        <field name="arch" type="xml">
            <form string="Fulfillment Order">
                <header>
                    <button name="action_confirm"
                            string="Confirm Order"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_view_picking"
                            string="📋 View Receipt"
                            type="object"
                            class="btn-secondary"
                            invisible="not picking_id"/>
                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            invisible="state in ('done', 'cancelled')"/>
                    <button name="action_reset_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,done"/>
                </header>
                <sheet>
                    <!-- stat buttons -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_picking"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-truck"
                                invisible="not picking_id">
                            <field name="picking_state" widget="badge"
                                decoration-secondary="picking_state == 'draft'"
                                decoration-info="picking_state in ('waiting', 'confirmed', 'assigned')"
                                decoration-success="picking_state == 'done'"
                                decoration-danger="picking_state == 'cancel'"
                                string="Receipt"/>
                        </button>
                        <button class="oe_stat_button" icon="fa-cubes" type="object" name="action_view_picking">
                            <field name="line_count" widget="statinfo" string="Products"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Order Info">
                            <field name="fulfillment_partner_id"
                                   readonly="state != 'draft'"
                                   options="{'no_create': True}"/>
                            <field name="source_warehouse_id"
                                   readonly="state != 'draft'"
                                   options="{'no_create': True}"/>
                            <field name="dest_warehouse_id"
                                   readonly="state != 'draft'"
                                   options="{'no_create': True}"/>
                        </group>
                        <group string="Receipt">
                            <field name="picking_id" readonly="1" options="{'no_create': True}"/>
                            <field name="fulfillment_transfer_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Products" name="products">
                            <field name="order_line_ids"
                                   readonly="state != 'draft'">
                                <list editable="bottom">
                                    <field name="product_id" options="{'no_create': True}"/>
                                    <field name="product_uom_qty" string="Qty"/>
                                    <field name="product_uom" string="Unit" options="{'no_create': True}"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" readonly="state != 'draft'"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_fulfillment_order" model="ir.actions.act_window">
        <field name="name">Fulfillment Orders</field>
        <field name="res_model">fulfillment.order</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Fulfillment Order
            </p>
            <p>
                Request goods to be sent from a fulfillment partner's warehouse to your own warehouse.
            </p>
        </field>
    </record>

</odoo>
