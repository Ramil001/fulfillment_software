<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_purchase_form_inherit_fulfillment" model="ir.ui.view">
    <field name="name">purchase.order.form.inherit.fulfillment</field>
    <field name="model">purchase.order</field>
    <field name="inherit_id" ref="purchase.purchase_order_form"/>
    <field name="arch" type="xml">
      <xpath expr="//sheet/notebook" position="inside">
        <page string="Fulfillment Software">
          <group>
            <field name="fulfillment_purchase_id" readonly="1"/>
          </group>
        </page>
      </xpath>
    </field>
  </record>
</odoo>
