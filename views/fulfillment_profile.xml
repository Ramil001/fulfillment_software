<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
               <record id="view_fulfillment_profile_form" model="ir.ui.view">
            <field name="name">fulfillment.profile.form</field>
            <field name="model">fulfillment.profile</field>
            <field name="arch" type="xml">
                <form string="Fulfillment Profile">
                    <sheet>
                        <group col="2">
                            <group>
                                <separator string="About your company" colspan="2"/>
                                <field name="name"/>
                                <field name="phone"/>
                                <field name="email"/>
                                <field name="verification_account" widget="badge"
                                    options="{'classes': {
                                        'verification': 'badge rounded-pill text-bg-success',
                                        'not_verification': 'badge rounded-pill text-bg-danger'
                                    }}"/>
                            </group>
                            <group>
                                <separator string="Address" colspan="2"/>
                                <field name="country_id"/>
                                <field name="state_id"/>
                                <field name="address"/>
                            </group>
                            <group>
                                <separator string="API connection" colspan="2"/>
                                <field name="api_domain" required="1"/>
                                <field name="fulfillment_api_key" password="True" required="1"/>
                            </group>
                            <group>
                                <separator string="Webhook"/>
                                <field name="webhook_domain" placeholder="example.com" required="1" />
                                 <field name="is_available_webhook" widget="badge"
                                    decoration-success="is_available_webhook == 'available'"
                                    decoration-warning="is_available_webhook == 'unavailable'"
                                 />
                                 <button 
                                    name="action_set_current_domain" 
                                    type="object" 
                                    string="Auto Setup Domain" 
                                    class="btn-primary"
                                />                        
                               
                            </group>
                            <group >
                                <separator string="Connect with Fulfillment Software" colspan="2"/>
                                <field name="update_at" password="True"/>
                                <field name="fulfillment_profile_id"></field>
                            </group>

                            <group col="2">
                                <separator string="Import settings" />
                                <field name="allow_auto_import"></field>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>