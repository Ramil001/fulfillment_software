<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>


       <record id="view_fulfillment_partners_form" model="ir.ui.view">
        <field name="name">fulfillment.partners.form</field>
        <field name="model">fulfillment.partners</field>
        <field name="arch" type="xml">
           <form string="Partner Details">
            <sheet>
                <group>
                    <field name="name"/>
                    <field name="domain"/>
                    </group>
            </sheet>

           <chatter/>
        
          </form>
        </field>
       </record>



        <record id="view_fulfillment_partners_list" model="ir.ui.view">
            <field name="name">fulfillment.partners.list</field>
            <field name="model">fulfillment.partners</field>
            <field name="arch" type="xml">
                <list string="Partners">
                    <header>
                        <button name="button_sync_from_api"
                        string="Update"
                        type="object"
                        class="oe_highlight"
                        display="always"/>
                    </header>
                    <field name="name"/>
                    <field name="domain"/>
                </list>
            </field>
        </record>



        <record id="action_fulfillment_partners" model="ir.actions.act_window">
            <field name="name">Partners</field>
            <field name="res_model">fulfillment.partners</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Update a new fulfillment partner
                </p>
            </field>
        </record>


    </data>
</odoo>