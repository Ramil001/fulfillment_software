<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <!-- Форма партнёра -->
    <record id="view_fulfillment_partners_form" model="ir.ui.view">
      <field name="name">fulfillment.partners.form</field>
      <field name="model">fulfillment.partners</field>
      <field name="arch" type="xml">
        <form string="Partner Details" create="False">
          <sheet>

            <!-- ── Smart buttons ── -->
            <div name="button_box" class="oe_button_box">

              <button name="action_view_warehouses" type="object"
                      class="oe_stat_button" icon="fa-warehouse">
                <field name="warehouse_count" widget="statinfo" string="Склады"/>
              </button>

              <button name="action_view_products" type="object"
                      class="oe_stat_button" icon="fa-cube">
                <field name="product_count" widget="statinfo" string="Продукты"/>
              </button>

              <button name="action_view_orders" type="object"
                      class="oe_stat_button" icon="fa-shopping-cart">
                <field name="order_count" widget="statinfo" string="Заказы"/>
              </button>

              <button name="action_view_clients" type="object"
                      class="oe_stat_button" icon="fa-users">
                <field name="client_count" widget="statinfo" string="Клиенты"/>
              </button>

              <button name="action_view_transfers" type="object"
                      class="oe_stat_button" icon="fa-exchange">
                <field name="transfer_count" widget="statinfo" string="Трансферы"/>
              </button>

              <button name="action_compose_send" type="object"
                      class="oe_stat_button" icon="fa-comments">
                <field name="unread_message_count" widget="statinfo" string="Сообщения"/>
              </button>

            </div>

            <!-- ── Заголовок ── -->
            <div class="oe_title">
              <field name="fulfillment_logo" widget="image" class="oe_avatar"/>
              <h1><field name="name"/></h1>
            </div>

            <group>
              <group>
                <field name="status" widget="radio"/>
                <field name="partner_id"/>
                <field name="fulfillment_id"/>
              </group>
              <group>
                <field name="api_domain"/>
                <field name="webhook_domain">
                  <button name="action_fill_webhook_domain" type="object"
                          string="Set domain" class="oe_link" icon="fa-globe"/>
                </field>
              </group>
            </group>

            <notebook>

              <!-- ── Склады ── -->
              <page string="Склады" name="warehouses">
                <group>
                  <separator string="Арендую у партнёра"/>
                  <field name="warehouses_client_ids" nolabel="1">
                    <list>
                      <field name="name"/>
                      <field name="code"/>
                      <field name="partner_id"/>
                      <field name="is_fulfillment"/>
                      <field name="fulfillment_warehouse_id"/>
                      <field name="last_update"/>
                    </list>
                  </field>
                </group>
                <group>
                  <separator string="Сдаю партнёру"/>
                  <field name="warehouses_owner_ids" nolabel="1">
                    <list>
                      <field name="name"/>
                      <field name="code"/>
                      <field name="partner_id"/>
                      <field name="is_fulfillment"/>
                      <field name="fulfillment_warehouse_id"/>
                      <field name="last_update"/>
                    </list>
                  </field>
                </group>
              </page>

              <!-- ── Продукты ── -->
              <page string="Продукты" name="products">
                <group>
                  <separator string="Продажи"/>
                  <field name="sale_product_ids" nolabel="1">
                    <list>
                      <field name="name"/>
                      <field name="default_code" string="SKU"/>
                      <field name="fulfillment_product_id"/>
                      <field name="type"/>
                    </list>
                  </field>
                </group>
                <group>
                  <separator string="Закупки"/>
                  <field name="purchase_product_ids" nolabel="1">
                    <list>
                      <field name="name"/>
                      <field name="default_code" string="SKU"/>
                      <field name="fulfillment_product_id"/>
                      <field name="type"/>
                    </list>
                  </field>
                </group>
              </page>

              <!-- ── Трансферы ── -->
              <page string="Трансферы" name="transfers">
                <group>
                  <separator string="Приходы (Incoming)"/>
                  <field name="transfers_purchase_ids" nolabel="1">
                    <list>
                      <field name="name"/>
                      <field name="origin"/>
                      <field name="partner_id"/>
                      <field name="location_id"/>
                      <field name="location_dest_id"/>
                      <field name="state"/>
                    </list>
                  </field>
                </group>
                <group>
                  <separator string="Внутренние"/>
                  <field name="transfers_internal_ids" nolabel="1">
                    <list>
                      <field name="name"/>
                      <field name="origin"/>
                      <field name="partner_id"/>
                      <field name="location_id"/>
                      <field name="location_dest_id"/>
                      <field name="state"/>
                    </list>
                  </field>
                </group>
                <group>
                  <separator string="Доставки (Outgoing)"/>
                  <field name="transfers_delivery_ids" nolabel="1">
                    <list>
                      <field name="name"/>
                      <field name="origin"/>
                      <field name="partner_id"/>
                      <field name="location_id"/>
                      <field name="location_dest_id"/>
                      <field name="state"/>
                    </list>
                  </field>
                </group>
              </page>

              <!-- ── Чат ── -->
              <page string="Чат" name="chat">

                <!-- Messages list -->
                <field name="message_ids_chat" nolabel="1" mode="list">
                  <list create="0" delete="0" decoration-info="direction == 'out'" decoration-success="direction == 'in' and is_read" decoration-warning="direction == 'in' and not is_read">
                    <field name="sent_at" string="Время" optional="show"/>
                    <field name="direction" widget="badge"
                           decoration-info="direction == 'out'"
                           decoration-success="direction == 'in'"
                           string="Направление"/>
                    <field name="content" string="Сообщение"/>
                    <field name="ref_type" string="Тип" optional="hide"/>
                    <field name="ref_id" string="Ссылка" optional="hide"/>
                    <field name="is_read" string="Прочитано" optional="show"/>
                  </list>
                </field>

                <!-- Compose area -->
                <separator string="Отправить сообщение"/>
                <group>
                  <field name="compose_content" nolabel="1"
                         placeholder="Введите сообщение…"
                         widget="text"/>
                </group>
                <div class="text-end mb-2">
                  <button name="action_compose_send" type="object"
                          string="Отправить" class="btn btn-primary"
                          icon="fa-paper-plane"/>
                </div>

              </page>

            </notebook>
          </sheet>
          <chatter/>
        </form>
      </field>
    </record>
    <!-- Список партнёров -->
    <record id="view_fulfillment_partners_list" model="ir.ui.view">
      <field name="name">fulfillment.partners.list</field>
      <field name="model">fulfillment.partners</field>
      <field name="arch" type="xml">
        <list string="Partners" create="False">
          <header>
            <button name="button_run_import_all"
                        string="Run import all"
                        type="object"
                        class="oe_highlight"
                        display="always"/>
          </header>
          <field name="name" />
          <field name="api_domain"/>
          <field name="webhook_domain" />
          <field name="status" widget="badge"
                decoration-success="status == 'follow'"
                decoration-warning="status == 'unfollow'"/>
        </list>
      </field>
    </record>
    <record id="action_fulfillment_partners" model="ir.actions.act_window">
      <field name="name">Partners</field>
      <field name="res_model">fulfillment.partners</field>
      <field name="view_mode">list,form</field>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          Update a new fulfillment partner
        </p>
      </field>
    </record>
  </data>
</odoo>