<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <!-- Форма партнёра -->
    <record id="view_fulfillment_partners_form" model="ir.ui.view">
      <field name="name">fulfillment.partners.form</field>
      <field name="model">fulfillment.partners</field>
      <field name="arch" type="xml">
        <form string="Partner Details" create="False">
          <sheet>
<header>
    
</header>
            <group >
              <group>
              <field name="status" widget="radio"/>  
              </group>
              <group>
              <field name="fulfillment_logo" widget="image" class="oe_avatar"/>  
              </group>
              
            </group>

            <group>
              <group>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="fulfillment_id"/>
              </group>
              <group>
                <field name="api_domain"/>
                <field name="webhook_url" />
              </group>
            </group>
            <notebook>
              <page string="Warehouses">
                <group>
                  <separator string="I Rent"/>
                  <field name="warehouses_client_ids" nolabel="1">
                    <list>
                      <field name="name"/>
                      <field name="code"/>
                      <field name="partner_id"/>
                      <field name="company_id"/>
                      <field name="is_fulfillment"/>
                      <field name="fulfillment_client_id"/>
                    </list>
                    <form>
                      <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="partner_id"/>
                        <field name="company_id"/>
                        <field name="is_fulfillment"/>
                        <field name="fulfillment_client_id"/>
                      </group>
                    </form>
                  </field>
                </group>
                <group>
                  <separator string="I Rent Out"/>
                  <field name="warehouses_owner_ids" nolabel="1">
                    <list>
                      <field name="name"/>
                      <field name="code"/>
                      <field name="partner_id"/>
                      <field name="company_id"/>
                      <field name="is_fulfillment"/>
                      <field name="fulfillment_client_id"/>
                    </list>
                    <form>
                      <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="partner_id"/>
                        <field name="company_id"/>
                        <field name="is_fulfillment"/>
                        <field name="fulfillment_client_id"/>
                      </group>
                    </form>
                  </field>
                </group>
              </page>
              <page string="Transfers">
                <group>
                  <separator string="Purchases (Incoming)"/>
                  <field name="transfers_purchase_ids" nolabel="1">
                    <list>
                      <field name="name"/>
                      <field name="origin"/>
                      <field name="partner_id"/>
                      <field name="location_id"/>
                      <field name="location_dest_id" />
                      <field name="fulfillment_partner_id" />
                      <field name="state"/>
                    </list>
                    <form>
                      <group>
                        <field name="name"/>
                        <field name="origin"/>
                        <field name="partner_id"/>
                        <field name="location_id"/>
                        <field name="location_dest_id" />
                        <field name="fulfillment_partner_id" />
                        <field name="state"/>
                      </group>
                    </form>
                  </field>
                </group>
                <group>
                  <separator string="Internal Transfers"/>
                  <field name="transfers_internal_ids" nolabel="1">
                    <list>
                      <field name="name"/>
                      <field name="origin"/>
                      <field name="partner_id"/>
                      <field name="location_id"/>
                      <field name="location_dest_id" />
                      <field name="fulfillment_partner_id" />
                      <field name="state"/>
                    </list>
                    <form>
                      <group>
                        <field name="name"/>
                        <field name="origin"/>
                        <field name="partner_id"/>
                        <field name="location_id"/>
                        <field name="location_dest_id" />
                        <field name="fulfillment_partner_id" />
                        <field name="state"/>
                      </group>
                    </form>
                  </field>
                </group>
                <group>
                  <separator string="Delivery Orders (Outgoing)"/>
                  <field name="transfers_delivery_ids" nolabel="1">
                    <list>
                      <field name="name"/>
                      <field name="origin"/>
                      <field name="partner_id"/>
                      <field name="location_id"/>
                      <field name="location_dest_id" />
                      <field name="fulfillment_partner_id" />
                      <field name="state"/>
                    </list>
                    <form>
                      <group>
                        <field name="name"/>
                        <field name="origin"/>
                        <field name="partner_id"/>
                        <field name="location_id"/>
                        <field name="location_dest_id" />
                        <field name="fulfillment_partner_id" />
                        <field name="state"/>
                      </group>
                    </form>
                  </field>
                </group>
              </page>
              <page string="Products"/>
            </notebook>
          </sheet>
          <!-- Chatter -->
          <chatter/>
        </form>
      </field>
    </record>
    <!-- Список партнёров -->
    <record id="view_fulfillment_partners_list" model="ir.ui.view">
      <field name="name">fulfillment.partners.list</field>
      <field name="model">fulfillment.partners</field>
      <field name="arch" type="xml">
        <list string="Partners" create="False">
          <header>
            <button name="button_run_import_all"
                        string="Run import all"
                        type="object"
                        class="oe_highlight"
                        display="always"/>
          </header>
          <field name="name" />
          <field name="api_domain"/>
          <field name="webhook_url" />
          <field name="status" widget="badge"
                decoration-success="status == 'follow'"
                decoration-warning="status == 'unfollow'"/>
        </list>
      </field>
    </record>
    <record id="action_fulfillment_partners" model="ir.actions.act_window">
      <field name="name">Partners</field>
      <field name="res_model">fulfillment.partners</field>
      <field name="view_mode">list,form</field>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          Update a new fulfillment partner
        </p>
      </field>
    </record>
  </data>
</odoo>