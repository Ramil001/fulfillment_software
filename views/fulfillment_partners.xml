<?xml version="1.0" encoding="utf-8"?>
<odoo>
 <data>

  <!-- Форма партнёра -->
  <record id="view_fulfillment_partners_form" model="ir.ui.view">
   <field name="name">fulfillment.partners.form</field>
   <field name="model">fulfillment.partners</field>
   <field name="arch" type="xml">
    <form string="Partner Details" create="False">
     <sheet>
      <header>
       <button class="oe_stat_button" 
                         type="object" 
                         icon="fa-plus"           
                         string="Follow"              
                         name="action_send_request_follow">
                         
                </button>
      <field name="status" widget="statusbar"  statusbar_visible="follow,unfollow"  statusbar_colors='{"follow":"red","unfollow":"blue"}'/>
      </header>
      <div name="button_box" position="inside">
       <button class="oe_stat_button" 
                         type="object" 
                         icon="fa-home"           
                         string="19 warehouses"              
                         name="action_get_vehicles_record">
                         
        </button>
        <button class="oe_stat_button" 
                         type="object" 
                         icon="fa-money"           
                         string="0.50$ per/package"              
                         name="action_get_vehicles_record">
                         
        </button>
          <button class="oe_stat_button" 
                         type="object" 
                         icon="fa-users"           
                         string="246 followers"              
                         name="action_get_vehicles_record">
                         
        </button>
      </div>
      <group>
       <group>
        <field name="name"/>
        <field name="domain"/>
       </group>
       <group>
        <field name="name"/>
        <field name="domain"/>
       </group>
      </group>
      <notebook>
      <page string="Services">
       
      </page>
       <page string="Categories">
       
      </page>
       <page string="Services">
       
      </page>
     </notebook>
     </sheet>
    <!-- Chatter -->
     <chatter/>
     
    </form>
   </field>
  </record>


  <!-- Список партнёров -->
  <record id="view_fulfillment_partners_list" model="ir.ui.view">
   <field name="name">fulfillment.partners.list</field>
   <field name="model">fulfillment.partners</field>
   <field name="arch" type="xml">
    <list string="Partners" create="False">
     <header>
      <button name="button_sync_from_api"
                        string="Update partners"
                        type="object"
                        class="oe_highlight"
                        display="always"/>
     </header>
     <field name="name"/>
     <field name="domain"/>
    </list>
   </field>
  </record>


  <record id="action_fulfillment_partners" model="ir.actions.act_window">
   <field name="name">Partners</field>
   <field name="res_model">fulfillment.partners</field>
   <field name="view_mode">list,form</field>
   <field name="help" type="html">
    <p class="o_view_nocontent_smiling_face">
                    Update a new fulfillment partner
                </p>
   </field>
  </record>
 </data>
</odoo>