<odoo>
    <record id="view_partner_form_fulfillment" model="ir.ui.view">
        <field name="name">res.partner.form.fulfillment</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <!-- Добавляем новую вкладку Fulfillment -->
            <xpath expr="//notebook" position="inside">
                <page string="Fulfillment">
                    <group>
                        <field name="fulfillment_contact_id"></field>
                        <field name="fulfillment_partner_id" />
                        <field name="fulfillment_warehouse_id"/>
                        <field name="linked_warehouse_id"/>
                    </group>
                </page>
            </xpath>

        </field>
    </record>
</odoo>
