<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend the Operation Type form with Fulfillment fields -->
    <record id="view_picking_type_form_inherit_fulfillment" model="ir.ui.view">
        <field name="name">stock.picking.type.form.inherit.fulfillment</field>
        <field name="model">stock.picking.type</field>
        <field name="inherit_id" ref="stock.view_picking_type_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Fulfillment Software" col="2">
                    <field name="fulfillment_operation_type" widget="radio"/>
                    <field name="fulfillment_partner_id"
                           options="{'no_create': True}"
                           invisible="not fulfillment_operation_type"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Action: list of Send to Fulfillment transfers -->
    <record id="action_picking_send_to_fulfillment" model="ir.actions.act_window">
        <field name="name">Send to Fulfillment</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('picking_type_id.fulfillment_operation_type', '=', 'send_to_fulfillment')]</field>
        <field name="context">{'default_picking_type_id': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Send goods to your fulfillment partner</p>
            <p>Create a transfer to ship products from your warehouse to the fulfillment partner's warehouse.</p>
        </field>
    </record>

    <!-- Action: list of Request from Fulfillment transfers -->
    <record id="action_picking_request_from_fulfillment" model="ir.actions.act_window">
        <field name="name">Request from Fulfillment</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('picking_type_id.fulfillment_operation_type', '=', 'request_from_fulfillment')]</field>
        <field name="context">{'default_picking_type_id': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Request goods from your fulfillment partner</p>
            <p>Create a transfer to receive products back from the fulfillment partner's warehouse.</p>
        </field>
    </record>

    <!-- Menu items under Inventory → Operations -->
    <menuitem id="menu_inventory_fulfillment_transfers"
              name="Fulfillment Transfers"
              parent="stock.menu_stock_warehouse_mgmt"
              sequence="25">
        <menuitem id="menu_inventory_send_to_fulfillment"
                  name="Send to Fulfillment"
                  action="action_picking_send_to_fulfillment"
                  sequence="1"/>
        <menuitem id="menu_inventory_request_from_fulfillment"
                  name="Request from Fulfillment"
                  action="action_picking_request_from_fulfillment"
                  sequence="2"/>
    </menuitem>
</odoo>
