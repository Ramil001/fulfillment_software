<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Tree View for Dashboard -->
        <record id="view_fulfillment_tree" model="ir.ui.view">
            <field name="name">fulfillment.dashboard.tree.custom</field>
            <field name="model">fulfillment.dashboard</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <list string="Fulfillment Dashboards">
                    <field name="name"/>
                    <field name="email"/>
                    <field name="phone"/>
                    <field name="subscription_count" string="Подписок"/>
                </list>
            </field>
        </record>


        <record id="view_fulfillment_profile_form" model="ir.ui.view">
            <field name="name">fulfillment.profile.form</field>
            <field name="model">fulfillment.profile</field>
            <field name="arch" type="xml">
                <form string="Fulfillment Profile">
                    <sheet>
                        <group col="2">
                            <group>
                                <separator string="Contact info" colspan="2"/>
                                <field name="name"/>
                                <field name="phone"/>
                                <field name="email"/>
                                <field name="verification_account" widget="badge"
                                    options="{'classes': {
                                        'verification': 'badge rounded-pill text-bg-success',
                                        'not_verification': 'badge rounded-pill text-bg-danger'
                                    }}"/>
                            </group>
                            <group>
                                <separator string="Address" colspan="2"/>
                                <field name="country_id"/>
                                <field name="state_id"/>
                                <field name="address"/>
                            </group>
                            <group>
                                <separator string="API connection" colspan="2"/>
                                <field name="api_domain" />
                                <field name="fulfillment_api_key" password="True"/>
                            </group>
                            <group>
                                <separator string="Webhook"/>
                                <field name="webhook_domain" placeholder="example.com'" />
                            </group>
                            <group >
                                <separator string="Connect with Fulfillment Software" colspan="2"/>
                                <field name="update_at" password="True"/>
                                <field name="fulfillment_profile_id"></field>
                            </group>
                        </group>
                       
                    </sheet>
                </form>
            </field>
        </record>



        <record id="view_subscription_form" model="ir.ui.view">
            <field name="name">fulfillment.subscription.form</field>
            <field name="model">fulfillment.subscription</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="dashboard_id"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>


        <record id="fulfillment_main" model="ir.actions.act_window">
            <field name="name">Fulfillment Dashboard</field>
            <field name="res_model">fulfillment.dashboard</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="view_fulfillment_tree"/>
        </record>

        
        <record id="fulfillment_my_account" model="ir.actions.act_window">
            <field name="name">My Fulfillment Account</field>
            <field name="res_model">fulfillment.profile</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_fulfillment_profile_form"/>
            <field name="target">current</field>
            <field name="context">{'create': False}</field>
        </record>


        <record id="action_my_fulfillment_profile" model="ir.actions.server">
            <field name="name">My Fulfillment Profile</field>
            <field name="model_id" ref="model_fulfillment_profile"/>
            <field name="binding_model_id" ref="model_fulfillment_profile"/>
            <field name="state">code</field>
            <field name="code">
                action = env['fulfillment.profile'].get_my_profile_action()
            </field>
        </record>




    </data>
</odoo>