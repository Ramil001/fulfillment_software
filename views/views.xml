<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Tree View for Dashboard -->
        <record id="view_fulfillment_tree" model="ir.ui.view">
            <field name="name">fulfillment.dashboard.tree.custom</field>
            <field name="model">fulfillment.dashboard</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <!-- ИСПРАВЛЕНО: используем <list> вместо <tree> -->
                <list string="Fulfillment Dashboards">
                    <field name="name"/>
                    <field name="email"/>
                    <field name="phone"/>
                    <field name="subscription_count" string="Подписок"/>
                </list>
            </field>
        </record>

        <!-- Form View for Dashboard -->
        <record id="view_fulfillment_form" model="ir.ui.view">
            <field name="name">fulfillment.dashboard.form</field>
            <field name="model">fulfillment.dashboard</field>
            <field name="arch" type="xml">
                <form string="Fulfillment Dashboard">
                    <header>
                        <button name="action_create_subscription" 
                                type="object"
                                string="Добавить подписку"
                                class="oe_highlight"/>
                    </header>
                    <sheet>
                        <group>
                            <separator string="Информация о вашей компании" colspan="2"/>
                            <label string="Название компании" for="name" />
                            <field name="name"/>
                            <label string="Корпоративная почта" for="email" />
                            <field name="email"/>
                            <label string="Контакты" for="phone" />
                            <field name="phone"/>
                        </group>
                        <group>
                            <separator string="" colspan="2"/>
                            <field name="description"/>
                        </group>
                        <notebook>
                            <page string="Мои склады">
                                <field name="warehouse_ids" widget="many2many_tags"/>
                            </page>
                            <page string="Мои подписчики">
                                <div class="o_form_label">Тут список подписчиков</div>
                            </page>
                            <page string="Мои подписки">
                                <field name="subscription_ids" nolabel="1">
                                    <!-- ИСПРАВЛЕНО: используем <list> для вложенного представления -->
                                    <list>
                                        <field name="name"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Tree View for Subscriptions -->
        <record id="view_subscription_tree" model="ir.ui.view">
            <field name="name">fulfillment.subscription.tree</field>
            <field name="model">fulfillment.subscription</field>
            <field name="arch" type="xml">
                <!-- ИСПРАВЛЕНО: используем <list> вместо <tree> -->
                <list string="Subscriptions">
                    <field name="name"/>
                    <field name="dashboard_id"/>
                </list>
            </field>
        </record>

        <!-- Form View for Subscriptions -->
        <record id="view_subscription_form" model="ir.ui.view">
            <field name="name">fulfillment.subscription.form</field>
            <field name="model">fulfillment.subscription</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="dashboard_id"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        
        <!-- Actions -->
        <record id="fulfillment_main" model="ir.actions.act_window">
            <field name="name">Fulfillment Dashboard</field>
            <field name="res_model">fulfillment.dashboard</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="view_fulfillment_tree"/>
        </record>

        <record id="fulfillment_my_account" model="ir.actions.act_window">
            <field name="name">My Fulfillment Account</field>
            <field name="res_model">fulfillment.dashboard</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_fulfillment_form"/>
        </record>

        <record id="action_subscription_tree" model="ir.actions.act_window">
            <field name="name">Subscriptions</field>
            <field name="res_model">fulfillment.subscription</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="view_subscription_tree"/>
        </record>
    </data>
</odoo>