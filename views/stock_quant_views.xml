<odoo>
  <!-- === FORM VIEW EXTENSION === -->
  <record id="view_stock_quant_form_editable_inherit_fulfillment" model="ir.ui.view">
    <field name="name">stock.quant.form.editable.fulfillment_stock_id</field>
    <field name="model">stock.quant</field>
    <field name="inherit_id" ref="stock.view_stock_quant_form_editable"/>
    <field name="arch" type="xml">
      <!-- вставляем после product_id -->
      <xpath expr="//field[@name='location_id']" position="after">
        <field name="fulfillment_stock_id"/>
      </xpath>
    </field>
  </record>

  <!-- === TREE VIEW EXTENSION === -->
  <record id="view_stock_quant_tree_inherit_fulfillment" model="ir.ui.view">
    <field name="name">stock.quant.tree.fulfillment_stock_id</field>
    <field name="model">stock.quant</field>
    <field name="inherit_id" ref="stock.view_stock_quant_tree"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='location_id']" position="after">
        <field name="fulfillment_stock_id"/>
      </xpath>
    </field>
  </record>
</odoo>
