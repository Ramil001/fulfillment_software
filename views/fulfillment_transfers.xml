<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_transfers_form_inherit_fulfillment" model="ir.ui.view">
    <field name="name">stock.picking.form.inherit.fulfillment</field>
    <field name="model">stock.picking</field>
    <field name="inherit_id" ref="stock.view_picking_form"/>
    <field name="arch" type="xml">
      <xpath expr="//sheet/notebook" position="inside">
        <page string="Fulfillment Software">
          <group>
            <field name="fulfillment_transfer_id"/>
            <field name="fulfillment_transfer_owner_id"/>
          </group>
        </page>
      </xpath>
    </field>
  </record>
</odoo>
