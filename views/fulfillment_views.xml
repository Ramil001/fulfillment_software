<odoo>
    <!-- Сначала объявляем все представления -->
    <record id="view_fulfillment_registration_form" model="ir.ui.view">
        <field name="name">fulfillment.registration.form</field>
        <field name="model">fulfillment.registration</field>
        <field name="type">form</field>  <!-- Добавлено явное указание типа -->
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="domain"/>
                        <field name="user_id"/>
                    </group>
                    <footer>
                        <button name="action_register" type="object" string="Зарегистрировать" class="btn-primary"/>
                        <button string="Отмена" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

<record id="view_fulfillment_list_tree" model="ir.ui.view">
    <field name="name">fulfillment.list.tree</field>
    <field name="model">fulfillment.list</field>
    <field name="type">tree</field>

    <field name="arch" type="xml">
        <tree>
            <field name="name"/>
            <field name="domain"/>
            <field name="user_id"/>
            <field name="created_at"/>
        </tree>
    </field>
</record>



    <!-- Затем объявляем действия -->
    <record id="action_fulfillment_registration" model="ir.actions.act_window">
        <field name="name">Зарегистрировать фулфилмент</field>
        <field name="res_model">fulfillment.registration</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="fulfillment_manager.view_fulfillment_registration_form"/>
    </record>

    <record id="action_fulfillment_list" model="ir.actions.act_window">
        <field name="name">Список фулфиллментов</field>
        <field name="res_model">fulfillment.list</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="fulfillment_manager.view_fulfillment_list_tree"/>
    </record>

    <!-- Меню -->
    <menuitem id="menu_fulfillment_root" name="Фулфилмент" sequence="10"/>
    <menuitem id="menu_fulfillment_registration" parent="menu_fulfillment_root" 
              action="action_fulfillment_registration" sequence="10"/>
    <menuitem id="menu_fulfillment_list" parent="menu_fulfillment_root" 
              action="action_fulfillment_list" sequence="20"/>
</odoo>