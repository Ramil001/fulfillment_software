<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- Kanban: Warehouse Network — one card = one fulfillment partner -->
    <record id="view_fulfillment_network_kanban" model="ir.ui.view">
      <field name="name">fulfillment.partners.network.kanban</field>
      <field name="model">fulfillment.partners</field>
      <field name="priority">10</field>
      <field name="arch" type="xml">
        <kanban string="Warehouse Network" default_order="name">
          <field name="id"/>
          <field name="name"/>
          <field name="fulfillment_logo"/>
          <field name="status"/>
          <field name="warehouse_count"/>
          <field name="transfer_count"/>
          <field name="product_count"/>
          <field name="client_count"/>
          <field name="order_count"/>
          <field name="api_domain"/>
          <templates>
            <t t-name="kanban-card">
              <div class="oe_kanban_global_click" style="border-radius:12px; overflow:hidden; box-shadow:0 2px 8px rgba(0,0,0,0.1); min-width:200px;">

                <!-- Шапка с градиентом -->
                <div style="background:linear-gradient(135deg,#714B67 0%,#017E84 100%); padding:16px; display:flex; align-items:center; gap:12px;">
                  <div style="width:48px; height:48px; border-radius:50%; background:rgba(255,255,255,0.25); display:flex; align-items:center; justify-content:center; font-size:20px; font-weight:bold; color:#fff; flex-shrink:0; overflow:hidden;">
                    <t t-if="record.fulfillment_logo.raw_value">
                      <img t-attf-src="/web/image/fulfillment.partners/#{record.id.raw_value}/fulfillment_logo"
                           style="width:48px; height:48px; object-fit:cover; border-radius:50%;"/>
                    </t>
                    <t t-else="">
                      <t t-esc="record.name.value and record.name.value[0] or '?'"/>
                    </t>
                  </div>
                  <div style="flex:1; min-width:0;">
                    <div style="color:#fff; font-weight:700; font-size:1rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                      <t t-esc="record.name.value"/>
                    </div>
                    <div style="margin-top:4px;">
                      <span t-attf-style="
                        background: #{record.status.raw_value == 'follow' ? '#28a745' : '#ffc107'};
                        color: #{record.status.raw_value == 'follow' ? '#fff' : '#000'};
                        padding: 2px 8px; border-radius: 10px; font-size: 0.7rem; font-weight:600;">
                        <t t-esc="record.status.value"/>
                      </span>
                    </div>
                  </div>
                </div>

                <!-- Статистика -->
                <div style="display:grid; grid-template-columns:repeat(4,1fr); text-align:center; background:#fafafa; border-bottom:1px solid #eee;">
                  <div style="padding:10px 4px; border-right:1px solid #eee;">
                    <div style="font-weight:700; font-size:1.1rem; color:#714B67;">
                      <t t-esc="record.warehouse_count.value"/>
                    </div>
                    <div style="font-size:0.62rem; color:#888; text-transform:uppercase; letter-spacing:.4px;">Склады</div>
                  </div>
                  <div style="padding:10px 4px; border-right:1px solid #eee;">
                    <div style="font-weight:700; font-size:1.1rem; color:#28a745;">
                      <t t-esc="record.product_count.value"/>
                    </div>
                    <div style="font-size:0.62rem; color:#888; text-transform:uppercase; letter-spacing:.4px;">Продукты</div>
                  </div>
                  <div style="padding:10px 4px; border-right:1px solid #eee;">
                    <div style="font-weight:700; font-size:1.1rem; color:#017E84;">
                      <t t-esc="record.order_count.value"/>
                    </div>
                    <div style="font-size:0.62rem; color:#888; text-transform:uppercase; letter-spacing:.4px;">Заказы</div>
                  </div>
                  <div style="padding:10px 4px;">
                    <div style="font-weight:700; font-size:1.1rem; color:#e67e22;">
                      <t t-esc="record.transfer_count.value"/>
                    </div>
                    <div style="font-size:0.62rem; color:#888; text-transform:uppercase; letter-spacing:.4px;">Трансферы</div>
                  </div>
                </div>

                <!-- Футер с доменом -->
                <div style="padding:8px 12px; background:#fff; min-height:32px;">
                  <t t-if="record.api_domain.raw_value">
                    <span style="font-size:0.72rem; color:#888; display:flex; align-items:center; gap:4px;">
                      <i class="fa fa-globe" style="color:#714B67;"/>
                      <span style="overflow:hidden; text-overflow:ellipsis; white-space:nowrap; max-width:180px; display:inline-block;">
                        <t t-esc="record.api_domain.value"/>
                      </span>
                    </span>
                  </t>
                  <t t-else="">
                    <span style="font-size:0.72rem; color:#ccc;">No API domain</span>
                  </t>
                </div>

              </div>
            </t>
          </templates>
        </kanban>
      </field>
    </record>

    <!-- Action: Warehouse Network -->
    <record id="action_fulfillment_network" model="ir.actions.act_window">
      <field name="name">Warehouse Network</field>
      <field name="res_model">fulfillment.partners</field>
      <field name="view_mode">kanban,list,form</field>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          Партнёры отсутствуют. Выполните синхронизацию, чтобы увидеть сеть складов.
        </p>
      </field>
    </record>

  </data>
</odoo>
