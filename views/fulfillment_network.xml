<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- Kanban: Warehouse Network — one card = one fulfillment partner -->
    <record id="view_fulfillment_network_kanban" model="ir.ui.view">
      <field name="name">fulfillment.partners.network.kanban</field>
      <field name="model">fulfillment.partners</field>
      <field name="priority">10</field>
      <field name="arch" type="xml">
        <kanban string="Warehouse Network" default_order="name">
          <templates>
            <t t-name="card">
              <!-- Header: logo + name + status -->
              <div class="d-flex align-items-center gap-2 p-2" style="background:linear-gradient(135deg,#714B67 0%,#017E84 100%);">
                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 overflow-hidden fw-bold text-white"
                     style="width:44px;height:44px;font-size:18px;background:rgba(255,255,255,0.25);">
                  <t t-if="record.fulfillment_logo.raw_value">
                    <img t-att-src="'/web/image/fulfillment.partners/' + record.id.raw_value + '/fulfillment_logo'"
                         style="width:44px;height:44px;object-fit:cover;border-radius:50%;"/>
                  </t>
                  <t t-else="">
                    <t t-out="record.name.value and record.name.value[0] or '?'"/>
                  </t>
                </div>
                <div class="flex-grow-1 overflow-hidden">
                  <div class="fw-bold text-white text-truncate" t-att-title="record.name.value">
                    <field name="name" readonly="1"/>
                  </div>
                  <field name="status" widget="badge" readonly="1"/>
                </div>
              </div>

              <!-- Stats grid -->
              <div class="row g-0 border-bottom text-center small">
                <div class="col border-end py-2">
                  <div class="fw-bold" style="color:#714B67;">
                    <field name="warehouse_count" readonly="1"/>
                  </div>
                  <div class="text-muted" style="font-size:0.65rem;text-transform:uppercase;">Склады</div>
                </div>
                <div class="col border-end py-2">
                  <div class="fw-bold text-success">
                    <field name="product_count" readonly="1"/>
                  </div>
                  <div class="text-muted" style="font-size:0.65rem;text-transform:uppercase;">Продукты</div>
                </div>
                <div class="col border-end py-2">
                  <div class="fw-bold" style="color:#017E84;">
                    <field name="order_count" readonly="1"/>
                  </div>
                  <div class="text-muted" style="font-size:0.65rem;text-transform:uppercase;">Заказы</div>
                </div>
                <div class="col py-2">
                  <div class="fw-bold text-warning">
                    <field name="transfer_count" readonly="1"/>
                  </div>
                  <div class="text-muted" style="font-size:0.65rem;text-transform:uppercase;">Трансферы</div>
                </div>
              </div>

              <!-- Footer: API domain -->
              <div class="px-2 py-1 small text-muted d-flex align-items-center gap-1">
                <t t-if="record.api_domain.raw_value">
                  <i class="fa fa-globe" style="color:#714B67;"/>
                  <span class="text-truncate" style="max-width:160px;">
                    <field name="api_domain" readonly="1"/>
                  </span>
                </t>
                <t t-else="">
                  <span class="fst-italic">No API domain</span>
                </t>
              </div>
            </t>
          </templates>
        </kanban>
      </field>
    </record>

    <!-- Action: Warehouse Network -->
    <record id="action_fulfillment_network" model="ir.actions.act_window">
      <field name="name">Warehouse Network</field>
      <field name="res_model">fulfillment.partners</field>
      <field name="view_mode">kanban,list,form</field>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          Партнёры отсутствуют. Выполните синхронизацию, чтобы увидеть сеть складов.
        </p>
      </field>
    </record>

  </data>
</odoo>
