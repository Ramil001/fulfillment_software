<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
<record id="view_order_line_tree_inherit_custom_note" model="ir.ui.view">
    <field name="name">sale.order.line.tree.inherit.custom.note</field>
    <field name="model">sale.order.line</field>
    <field name="inherit_id" ref="sale.view_order_line_tree"/> <!-- родной tree view -->
    <field name="arch" type="xml">
        <!-- вставляем поле после поля product_id -->
        <xpath expr="//field[@name='product_id']" position="after">
            <field name="fulfillment_partner_id"/>
        </xpath>
    </field>
</record>

</odoo>