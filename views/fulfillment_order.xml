<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

<record id="sale_order_line_form_inherit_fulfillment_partner" model="ir.ui.view">
    <field name="name">sale.order.line.form.inherit.fulfillment.partner</field>
    <field name="model">sale.order</field> 
    <field name="inherit_id" ref="sale.view_order_form"/>
    <field name="arch" type="xml">
       <xpath expr="//field[@name='order_line']/list//field[@name='route_id']" position="after">
           <field name="fulfillment_item_manager"/>
           <field name="fulfillment_item_warehouse"/>
       </xpath>

    </field>
</record>

<record id="sale_order_form_fulfillment" model="ir.ui.view">
 <field name="name">sale.order.form.inherit.fulfillment.tab</field>
    <field name="model">sale.order</field>
    <field name="inherit_id" ref="sale.view_order_form"/>
    <field name="arch" type="xml">
    <!-- Добавил поле выбора типа обработки заказа -->
  <xpath expr="//div[@class='oe_title']" position="before">
    <div class="mb-1">
        <label class="fw-bold d-block">Order Processing Type</label>
        <div class="mt-1">
            <field name="processing_mode" widget="selection"/>
        </div>
    </div>
</xpath>
      <!-- Добавляем новую вкладку внутрь notebook -->
      <xpath expr="//notebook" position="inside">
        <page string="Fulfillment">
          <group>
            <field name="fulfillment_order_id"/>
          </group>
        </page>
      </xpath>

    </field>
</record>

</odoo>