<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

<record id="sale_order_line_form_inherit_fulfillment_partner" model="ir.ui.view">
    <field name="name">sale.order.line.form.inherit.fulfillment.partner</field>
    <field name="model">sale.order</field> <!-- именно sale.order -->
    <field name="inherit_id" ref="sale.view_order_form"/> <!-- родная форма Sales Order -->
    <field name="arch" type="xml">
        <!-- вставляем поле после product_id внутри order_line/form -->
       <xpath expr="//field[@name='order_line']/list//field[@name='route_id']" position="after">
           <field name="fulfillment_partner_id"/>
       </xpath>

    </field>
</record>



</odoo>