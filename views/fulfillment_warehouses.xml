<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_warehouse_form_inherit_fulfillment" model="ir.ui.view">
        <field name="name">stock.warehouse.form.inherit.fulfillment</field>
        <field name="model">stock.warehouse</field>
        <field name="inherit_id" ref="stock.view_warehouse"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='warehouse_config']" position="inside">
                <group>
                    <separator string="Fulfillment Software" colspan="2"/>
                    <group string="Info">
                        <field name="warehouse_role" widget="badge"
                            decoration-success="warehouse_role == 'own'"
                            decoration-info="warehouse_role == 'rented'"
                            decoration-warning="warehouse_role == 'leased_out'"/>
                        <field name="fulfillment_warehouse_id"/>
                        <field name="fulfillment_owner_id"/>
                        <field name="fulfillment_client_id"/>
                        <field name="last_update"/>
                    </group>
                    <group string="Settings">
                        <field name="fulfillment_network_partner_id"
                            options="{'no_create': True}"
                            domain="[('partner_id', '!=', False)]"/>
                        <field name="is_fulfillment"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
