<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

  <record id="cron_poll_fulfillment_messages" model="ir.cron">
    <field name="name">Fulfillment: Poll new inter-instance messages</field>
    <field name="model_id" ref="fulfillment_software.model_fulfillment_message"/>
    <field name="state">code</field>
    <field name="code">model._poll_new_messages()</field>
    <field name="user_id" ref="base.user_root"/>
    <field name="interval_number">1</field>
    <field name="interval_type">minutes</field>
    <field name="active">True</field>
  </record>

</odoo>
