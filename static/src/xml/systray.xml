<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
  <t t-name="systray_icon" owl="1">
    <Dropdown>
      <div class="new_icon">
        <div class="icon_div">
          <div class="toggle-icon" role="button">
            <i
              class="fa fa-cube"
              title="Fulfillment Software"
              style="cursor:pointer; font-size:18px; margin:auto; display:flex;"
            />
          </div>
        </div>
      </div>
      <t t-set-slot="content">
        <DropdownItem onSelected="() => this.runImportAll()">
                    Sync All
        </DropdownItem>
        <DropdownItem onSelected="() => this.openProfiles()">
          Profiles
        </DropdownItem>

        <DropdownItem onSelected="() => this.openPartners()">
          Partners
        </DropdownItem>
      </t>
    </Dropdown>
  </t>
</templates>
